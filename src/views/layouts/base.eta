<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Board Game Score Keep — track your game nights">
  <title><%= it.title ? it.title + ' | ' : '' %>Board Game Score Keep</title>

  <script>try{var t=localStorage.getItem('theme');if(t&&t!=='auto')document.documentElement.dataset.theme=t}catch(e){}</script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link rel="stylesheet" href="/css/tokens.css">
  <link rel="stylesheet" href="/css/reset.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css">
  <% if (it.keepLayout) { %>
  <link rel="stylesheet" href="/css/keep.css">
  <% } %>
  <link rel="stylesheet" href="/css/game-theme.css">
  <link rel="stylesheet" href="/css/dark.css">

  <% if (it.game) { %>
  <style>
    body {
      --game-primary:   <%= it.game.color_primary   || '#5a3e2b' %>;
      --game-secondary: <%= it.game.color_secondary || '#e8d5a3' %>;
      --game-accent:    <%= it.game.color_accent     || '#c9a84c' %>;
    }
  </style>
  <% } %>

  <script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.1/bundles/datastar.js"></script>
  <script type="module" src="/js/main.js"></script>
</head>
<body class="<%= it.keepLayout ? 'keep-layout' : '' %> <%= it.game ? 'game-layout' : '' %>">

  <a href="#main-content" class="skip-nav">Skip to main content</a>

  <header class="site-header" role="banner" data-signals="{menuOpen:false}" data-on:click__outside="$menuOpen = false">
    <a href="/" class="site-header__logo" aria-label="Board Game Score Keep — Home">⚔ The Keep</a>

    <button class="site-header__menu-btn"
            aria-label="Toggle navigation menu"
            data-attr:aria-expanded="$menuOpen"
            data-class:is-open="$menuOpen"
            data-on:click="$menuOpen = !$menuOpen">
      <span class="site-header__menu-icon" aria-hidden="true"></span>
    </button>

    <nav class="site-header__nav" aria-label="Main navigation">
      <% if (it.user) { %>
      <a href="/games">My Games</a>
      <a href="/players">Players</a>
      <theme-toggle aria-label="Toggle dark mode"></theme-toggle>
      <form action="/auth/logout" method="POST" style="margin:0">
        <button type="submit" class="btn btn--ghost" style="color:inherit">Sign Out</button>
      </form>
      <% } else { %>
      <a href="/auth/login">Sign In</a>
      <a href="/auth/register" class="btn btn--gold">Create Account</a>
      <% } %>
    </nav>

    <div class="site-header__mobile-menu"
         data-show="$menuOpen"
         aria-label="Navigation menu">
      <% if (it.user) { %>
      <a href="/games" class="site-header__mobile-link">My Games</a>
      <a href="/players" class="site-header__mobile-link">Players</a>
      <div style="display:flex;align-items:center;gap:var(--space-2);padding:var(--space-1) var(--space-2)">
        <theme-toggle aria-label="Toggle dark mode"></theme-toggle>
      </div>
      <form action="/auth/logout" method="POST" style="margin:0">
        <button type="submit" class="site-header__mobile-link" style="width:100%;text-align:left;background:none;border:none;cursor:pointer;font:inherit;color:inherit">Sign Out</button>
      </form>
      <% } else { %>
      <a href="/auth/login" class="site-header__mobile-link">Sign In</a>
      <a href="/auth/register" class="site-header__mobile-link">Create Account</a>
      <% } %>
    </div>
  </header>

  <% if (it.game) { %>
  <div class="game-accent-bar" role="presentation"></div>
  <% } %>

  <main id="main-content" tabindex="-1">
    <%~ it.body %>
  </main>

  <footer class="site-footer" role="contentinfo">
    <p>Board Game Score Keep &mdash; Keep your victories close.</p>
  </footer>

  <div id="status-announcer"
       role="status"
       aria-live="polite"
       aria-atomic="true"
       class="visually-hidden"></div>


</body>
</html>
